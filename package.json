{
  "name": "@crouton-kit/crouter",
  "version": "0.2.6",
  "description": "crtr — fast access to skills, plugins, and marketplaces",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "crtr": "bin/crtr",
    "crouter": "bin/crouter"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc && rm -rf dist/builtin-skills && cp -R src/builtin-skills dist/builtin-skills",
    "dev": "tsx src/cli.ts",
    "link": "npm link",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crouton-labs/crouter.git"
  },
  "license": "MIT",
  "dependencies": {
    "@crouton-kit/humanloop": "file:.yalc/@crouton-kit/humanloop",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
