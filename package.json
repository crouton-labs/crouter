{
  "name": "@crouton-kit/crouter",
  "version": "0.3.18",
  "description": "crtr — fast access to skills, plugins, and marketplaces",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "crtr": "bin/crtr",
    "crouter": "bin/crouter",
    "crtrd": "bin/crtrd"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc && cp -R src/builtin-skills dist/builtin-skills && cp -R src/builtin-personas dist/builtin-personas && cp -R src/builtin-views dist/builtin-views && cp -R src/builtin-memory dist/builtin-memory",
    "dev": "tsx src/cli.ts",
    "link": "npm link",
    "prepublishOnly": "npm run build",
    "test": "node --import tsx/esm --test 'src/**/__tests__/**/*.test.ts'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crouton-labs/crouter.git"
  },
  "license": "MIT",
  "dependencies": {
    "@crouton-kit/humanloop": "latest",
    "commander": "^13.0.0",
    "cron-parser": "5.5.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
